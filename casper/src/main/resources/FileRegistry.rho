// FileRegistry.rho
//
// Structural analogy with SystemVault.rho:
//
//   SystemVault concept          |  FileRegistry equivalent
//   -----------------------------|------------------------------------------
//   vaultMap (TreeHashMap)       |  fileMap (TreeHashMap[hash -> fileHandle])
//   _systemVault (priv unf.)     |  _fileRegistry (priv unf.)
//   deployerAuthKey -> AuthKey   |  ownerAuthKey  -> AuthKey  (bound to hash)
//   transfer(auth, ret)          |  delete(auth, ret)
//   _transferTemplate            |  _deleteTemplate
//   MakeMint / purse (I/O)       |  rho:io:file system process (I/O)
//
// Flow for delete -- mirrors transfer:
//   1. Caller obtains authKey via FileRegistry!("ownerAuthKey", ...)
//      (only possible in the deploy that registered the file, i.e., the owner's deploy)
//   2. Caller calls fileHandle!("delete", authKey, *ret)
//   3. _deleteTemplate validates AuthKey shape = (_fileRegistry, fileHash)
//   4. If valid -> calls rho:io:file!("delete", fileHash, sysAuthToken, *sysCh)
//   5. System process validates SysAuthToken, schedules physical file removal
//   6. fileHandle is consumed (record removed from fileMap)
//
// Security: The system process rho:io:file requires a SysAuthToken for "delete".
//   SysAuthToken is a special unforgeable type (GSysAuthTokenBody) that CANNOT
//   be constructed by user Rholang code -- only the Scala runtime creates them.
//   FileRegistry receives one at genesis init time and keeps it on a private channel.
//   This means: no user deploy can bypass FileRegistry to call the system process directly.
//
new
  FileRegistry,
  rs(`rho:registry:insertSigned:secp256k1`),
  uriOut,
  rl(`rho:registry:lookup`),
  AuthKeyCh,
  EitherCh,
  TreeHashMapCh,
  sysAuthTokenOps(`sys:authToken:ops`),
  // Fixed channel: the rho:io:file system process produces delegation data here
  // after successful sig verification + phlo charging.
  registerNotify(`rho:io:file:registerNotify`),
  // Private unforgeable -- the "shape secret" for AuthKey.
  // Analogous to _systemVault in SystemVault.rho.
  // Never exposed outside this contract; makes AuthKeys unforgeable.
  _fileRegistry,
  // Stores the SysAuthToken received at genesis init (exactly once).
  // Passed to rho:io:file!("delete", ...) as proof that the caller is FileRegistry.
  // Analogous to how PoS.rho stores sysAuthToken and passes it to chargeDeploy/slash.
  _sysAuthTokenCh,
  // One-shot flag: consumed on first registerNotify to store the token.
  _tokenInitFlag,
  // Internal dispatch channels -- never exported
  _newFileHandle,
  _deleteTemplate
in {
  rl!(`rho:system:authKey`,    *AuthKeyCh)  |
  rl!(`rho:lang:either`,       *EitherCh)   |
  rl!(`rho:lang:treeHashMap`,  *TreeHashMapCh) |

  for (@(_, AuthKey)  <- AuthKeyCh &
       @(_, Either)   <- EitherCh  &
       TreeHashMap    <- TreeHashMapCh) {

    // -- SELF-INITIALIZING TOKEN STORAGE (one-shot) -----------------------
    //
    // _tokenInitFlag starts with an initial value. On the first registerNotify
    // call, the flag is consumed (destructive read) and the sysAuthToken is
    // stored on _sysAuthTokenCh. Subsequent calls find the flag empty and
    // skip the produce, preventing unbounded channel growth.
    _tokenInitFlag!(true) |

    // fileMap: TreeHashMap[fileHash:String -> fileHandle:Name]
    // Depth 3 -> 3*8 = 24-bit prefix parallelism, adequate for millions of files.
    new fileMapStore in {
      TreeHashMap!("init", 3, *fileMapStore) |
      for (@fileMap <- fileMapStore) {

        // -- PUBLIC API --------------------------------------------------------

        // register(fileHash, fileName, ownerDeployerId, sysAuthToken, ret)
        //   Called internally by the rho:io:file system process after confirming the
        //   node-signed envelope. The underlying file ingestion layer has already
        //   strictly enforced byte boundaries and deducted the storage-proportional
        //   Phlo cost prior to deploy construction, preventing disk exhaustion.
        //   Protected by sysAuthToken to prevent spoofing from native user Rholang deploys.
        //   Returns (true, fileHandle) on success. Appends to deployers array if duplicate.
        contract FileRegistry(@"register", @fileHash, @fileName, ownerDeployerId, @sysAuthToken, ret) = {
          new isValidCh in {
            sysAuthTokenOps!("check", sysAuthToken, *isValidCh) |
            for (@isValid <- isValidCh) {
              if (isValid) {
                new existingCh in {
                  TreeHashMap!("get", fileMap, fileHash, *existingCh) |
                  for (@existing <- existingCh) {
                    if (existing != Nil) {
                      // Duplicate -- file already registered. Get the capability.
                      // We add this deployer to the reference counted array.
                      // `existing` is already bundle+{*fileHandle} from TreeHashMap.
                      @existing!("addDeployer", *ownerDeployerId, *ret)
                    } else {
                      // Create the per-file handle and insert into fileMap.
                      new fileHandleCh, ackCh in {
                        _newFileHandle!(fileHash, fileName, *ownerDeployerId, *fileHandleCh) |
                        for (fileHandle <- fileHandleCh) {
                          TreeHashMap!("set", fileMap, fileHash, bundle+{*fileHandle}, *ackCh) |
                          for (_ <- ackCh) {
                            ret!((true, bundle+{*fileHandle}))
                          }
                        }
                      }
                    }
                  }
                }
              } else {
                ret!((false, "Invalid SysAuthToken"))
              }
            }
          }
        } |

        // -- SYSTEM PROCESS DELEGATION BRIDGE ---------------------------------
        //
        // Persistent listener on the rho:io:file:registerNotify fixed channel.
        // The rho:io:file system process (Scala) produces (fileHash, fileName,
        // deployerId, sysAuthToken) here after successful sig verification
        // and phlo charging.
        //
        // On the first call, we also store the sysAuthToken in _sysAuthTokenCh
        // for later use by _deleteTemplate. This replaces the old genesis init.
        //
        contract registerNotify(@fileHash, @fileName, ownerDeployerId, @sysAuthToken) = {
          new regAckCh in {
            // Store token exactly once (one-shot flag pattern):
            // Destructive read of _tokenInitFlag only succeeds on the first call.
            // Subsequent calls find _tokenInitFlag empty and go straight to register.
            for (_ <- _tokenInitFlag) {
              _sysAuthTokenCh!(sysAuthToken)
            } |
            FileRegistry!("register", fileHash, fileName, *ownerDeployerId, sysAuthToken, *regAckCh)
          }
        } |

        // ownerAuthKey(fileHash, ownerDeployerId, ret)
        //   Issues an AuthKey that proves ownership of `fileHash`.
        //   Shape = (_fileRegistry, fileHash, callerPubKey)
        //   Looks up the fileHandle via TreeHashMap and queries its state
        //   through the getInfo method (uses unforgeable private channel).
        contract FileRegistry(@"ownerAuthKey", @fileHash, ownerDeployerId, ret) = {
          new DeployerIdOps(`rho:system:deployerId:ops`),
              pubKeyCh, handleCh, infoCh
          in {
            DeployerIdOps!("pubKeyBytes", *ownerDeployerId, *pubKeyCh) |
            TreeHashMap!("get", fileMap, fileHash, *handleCh) |
            for (@callerPubKey <- pubKeyCh & @existing <- handleCh) {
              if (existing == Nil) {
                ret!(Nil)
              } else {
                // Query state via the fileHandle's getInfo method
                @existing!("getInfo", *infoCh) |
                for (@state <- infoCh) {
                  if (state.get("deployers").contains(callerPubKey)) {
                    // Caller is an owner -- issue the AuthKey bound to their specific key.
                    @AuthKey!("make", (*_fileRegistry, fileHash, callerPubKey), *ret)
                  } else {
                    ret!(Nil)
                  }
                }
              }
            }
          }
        } |

        // lookup(fileHash, ret)
        contract FileRegistry(@"lookup", @fileHash, ret) = {
          TreeHashMap!("get", fileMap, fileHash, *ret)
        } |

        // -- INTERNAL CONSTRUCTORS ---------------------------------------------

        // _newFileHandle(fileHash, fileName, ownerDeployerId, ret)
        contract _newFileHandle(@fileHash, @fileName, ownerDeployerId, ret) = {
          new DeployerIdOps(`rho:system:deployerId:ops`), pubKeyCh in {
            DeployerIdOps!("pubKeyBytes", *ownerDeployerId, *pubKeyCh) |
            for (@ownerPubKey <- pubKeyCh) {
              // Use an unforgeable private channel for state instead of a
              // globally-accessible tuple-keyed channel @{["fileState", fileHash]}.
              // This prevents arbitrary deploys from reading/writing the deployers map.
              new fileStateCh in {
                fileStateCh!({ "deployers": { ownerPubKey: true }, "name": fileName }) |

                new fileHandle in {

                  // addDeployer(newDeployerId, ret)
                  //   Appends deployer to the reference counted array if not present.
                  contract fileHandle(@"addDeployer", newDeployerId, ret) = {
                     new pubKeyCh in {
                       DeployerIdOps!("pubKeyBytes", *newDeployerId, *pubKeyCh) |
                       for (@newPubKey <- pubKeyCh) {
                         for (@state <- fileStateCh) {
                           if (state.get("deployers").contains(newPubKey)) {
                             // Already an owner
                             fileStateCh!(state) |
                             ret!((true, bundle+{*fileHandle}))
                           } else {
                             // Add to deployers map
                             fileStateCh!(state.set("deployers", state.get("deployers").set(newPubKey, true))) |
                             ret!((true, bundle+{*fileHandle}))
                           }
                         }
                       }
                     }
                  } |

                  // delete(callerPubKey, authKey, ret)
                  contract fileHandle(@"delete", @callerPubKey, authKey, ret) = {
                    _deleteTemplate!(fileHash, callerPubKey, *authKey, *fileStateCh, *ret)
                  } |

                  contract fileHandle(@"getInfo", ret) = {
                    for (@state <<- fileStateCh) {
                      ret!(state)
                    }
                  } |

                  ret!(*fileHandle)
                }
              }
            }
          }
        } |

        // _deleteTemplate(fileHash, callerPubKey, authKey, fileStateCh, ret)
        //   1. Validates AuthKey matches callerPubKey.
        //   2. Removes callerPubKey from deployers array.
        //   3. If array is empty -> calls rho:io:file!("delete") & deletes from fileMap.
        contract _deleteTemplate(@fileHash, @callerPubKey, authKey, fileStateCh, ret) = {
          new authValidCh, authValidEitherCh,
              sysDeleteCh, sysDeleteEitherCh,
              removeAckCh,
              fileProc(`rho:io:file`),
              filteredCh, filterPred
          in {
            // Step 1 -- Validate AuthKey shape.
            @AuthKey!("check", *authKey, (*_fileRegistry, fileHash, callerPubKey), *authValidCh) |
            @Either!("fromBoolean <-", *authValidCh, "Invalid AuthKey", *authValidEitherCh) |

            // Predicate for filtering: keep deployers that are NOT the caller.
            contract filterPred(@deployer, resultCh) = {
              resultCh!(deployer != callerPubKey)
            } |

            for (@authResult <- authValidEitherCh) {
              match authResult {
                (false, _) => { ret!(authResult) }
                _ => {
                  // Step 2 -- Update deployers map (remove callerPubKey)
                  for (@state <- fileStateCh) {
                    match state.get("deployers").delete(callerPubKey) {
                      remainingDeployers => {
                        if (remainingDeployers.size() == 0) {
                          // Map is empty! Reference count is 0. Time to delete physical file.
                          for (@storedToken <<- _sysAuthTokenCh) {
                            fileProc!("delete", fileHash, storedToken, *sysDeleteCh) |
                            for (@sysResult <- sysDeleteCh) {
                              @Either!("fromBoolean", sysResult, "System process delete failed", *sysDeleteEitherCh) |
                              for (@deleteEither <- sysDeleteEitherCh) {
                                match deleteEither {
                                  (false, errMsg) => {
                                    // Restore state on sys failure
                                    fileStateCh!(state) |
                                    ret!((false, errMsg))
                                  }
                                  _ => {
                                    // Step 3 -- Remove from TreeHashMap
                                    TreeHashMap!("delete", fileMap, fileHash, *removeAckCh) |
                                    for (_ <- removeAckCh) {
                                      ret!((true, fileHash))
                                    }
                                  }
                                }
                              }
                            }
                          }
                        } else {
                          // Other deployers still reference this file. Just update map.
                          fileStateCh!(state.set("deployers", remainingDeployers)) |
                          ret!((true, fileHash))
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    } |

    rs!(
      "0485e31ef85dca84b1b6134b6cef9e70f43c34586404c74fac172972aae18d1d4a45e5b116334796deb6e210e1a8c5962b9f30edcd5b723200234725c83eae56f6".hexToBytes(),
      (9223372036854775807, bundle+{*FileRegistry}),
      "304402207b0988ffbb06b31a07d4ab3a7a455696cb4617b98a576816537163abab233dfa022078f8ca749fa640ed0c5666633e0f899da64661f3f8501b5e39d5f229ba8e70ac".hexToBytes(),
      *uriOut
    )

  }
}
